# StockPulse AI - API Keys
# Copy this file to .env.local and fill in your keys

# Google Gemini AI (primary AI engine for deep analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Financial Modeling Prep (real-time quotes, historical data, financials, peers)
FMP_API_KEY=your_fmp_api_key_here

# Finnhub (real-time prices, live news, analyst recommendations, sentiment)
FINNHUB_API_KEY=your_finnhub_api_key_here

# OpenAI (optional fallback AI engine)
# OPENAI_API_KEY=your_openai_api_key_here
