# StockPulse — copy to .env.local (local) or Vercel Environment Variables

# --- AI & market data (required for full terminal) ---
GEMINI_API_KEY=your_gemini_api_key_here
FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
NEWS_API_KEY=your_newsapi_key_here

# OPENAI_API_KEY=optional_fallback

# --- Lifetime monetization ($29 one-time) ---
# Public Payment Link (Stripe Dashboard → Payment Links → $29 one-time)
STRIPE_LIFETIME_PAYMENT_LINK=https://buy.stripe.com/your_link

# Server-side Stripe (verify checkout + webhooks)
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Custom lifetime activation code (optional; default PULSE29)
# SP_LIFETIME_CODE=YOURSECRET

# Trial beta code (optional; defaults include PULSE14, EDGE2026)
# SP_BETA_CODE=YOURBETA

# Dev: disable all limits (treat as lifetime)
# SP_DISABLE_LIMITS=true
